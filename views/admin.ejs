<%- include("partials/header", { pageTitle }) %>

<main class="admin-page">
  <section class="admin-hero">
    <div>
      <p class="section-kicker">Панель управления</p>
      <h1>Управление контентом</h1>
      <p>Добавляйте обычные и VIP-программы, обновляйте галерею изображений и меняйте ZIP или EXE-файлы.</p>
    </div>
    <div class="admin-hero__user">
      <span>Текущий администратор</span>
      <strong><%= currentUser.email %></strong>
      <a href="/account" class="button button--ghost button--compact">Личный кабинет</a>
    </div>
  </section>

  <div class="admin-layout">
    <aside class="admin-panel">
      <h2><%= productToEdit ? "Редактировать продукт" : "Новый продукт" %></h2>

      <form
        class="product-form"
        method="post"
        action="<%= productToEdit ? `/admin/products/${productToEdit.id}/edit` : '/admin/products' %>"
        enctype="multipart/form-data"
      >
        <label>
          <span>Целевой сервис</span>
          <select name="service" required>
            <option value="">Выберите сервис...</option>
            <% services.forEach((service) => { %>
              <option
                value="<%= service.key %>"
                <%= productToEdit && productToEdit.service === service.key ? "selected" : "" %>
              >
                <%= service.name %>
              </option>
            <% }) %>
          </select>
        </label>

        <label>
          <span>Категория программы</span>
          <select name="programType" required>
            <option value="regular" <%= !productToEdit || !productToEdit.isVip ? "selected" : "" %>>
              Обычная программа
            </option>
            <option value="vip" <%= productToEdit && productToEdit.isVip ? "selected" : "" %>>
              VIP-программа
            </option>
          </select>
        </label>

        <label>
          <span>Тип</span>
          <input
            type="text"
            name="productType"
            placeholder="Например: Расширение, EXE, Приложение"
            value="<%= productToEdit ? productToEdit.productType : 'Расширение' %>"
          />
        </label>

        <label class="checkbox-field">
          <input
            type="checkbox"
            name="isNew"
            <%= productToEdit && productToEdit.isNew ? "checked" : "" %>
          />
          <span>Показывать на карточке красную метку «Новая»</span>
        </label>

        <label>
          <span>Название продукта</span>
          <input
            type="text"
            name="title"
            placeholder="Например: Litnet Cover Helper"
            value="<%= productToEdit ? productToEdit.title : '' %>"
            required
          />
        </label>

        <label>
          <span>Полное описание</span>
          <textarea
            name="description"
            rows="6"
            placeholder="Опишите, что делает продукт, как он выглядит и чем полезен."
            required
          ><%= productToEdit ? productToEdit.description : '' %></textarea>
        </label>

        <label>
          <span>Галерея изображений</span>
          <% if (productToEdit && productToEdit.imagePaths && productToEdit.imagePaths.length) { %>
            <div class="admin-gallery-preview">
              <% productToEdit.imagePaths.forEach((imagePath, index) => { %>
                <figure class="admin-gallery-preview__item">
                  <img src="<%= imagePath %>" alt="<%= productToEdit.title %> <%= index + 1 %>" />
                  <figcaption><%= index === 0 ? "Обложка" : `Фото ${index + 1}` %></figcaption>
                </figure>
              <% }) %>
            </div>
          <% } %>

          <input
            type="file"
            name="images"
            accept=".png,.jpg,.jpeg,.webp,.svg"
            multiple
            <%= productToEdit ? "" : "required" %>
          />
          <p class="form-hint">
            Можно выбрать сразу несколько файлов. Первая картинка станет обложкой карточки.
            <% if (productToEdit) { %>
              Если загрузите новый набор, текущая галерея будет заменена.
            <% } %>
          </p>
        </label>

        <label>
          <span>Файл продукта (ZIP или EXE)</span>
          <% if (productToEdit) { %>
            <div class="form-hint form-hint--inline">Текущий файл: <%= productToEdit.originalFileName %></div>
          <% } %>
          <input type="file" name="archive" accept=".zip,.exe" <%= productToEdit ? "" : "required" %> />
        </label>

        <button class="button button--primary button--full" type="submit">
          <%= productToEdit ? "Сохранить изменения" : "Опубликовать на сайте" %>
        </button>

        <% if (productToEdit) { %>
          <a href="/admin" class="button button--ghost button--full">Отмена</a>
        <% } %>
      </form>
    </aside>

    <div class="admin-panel">
      <div class="admin-panel__heading">
        <h2>Опубликованные карточки <span><%= products.length %> шт.</span></h2>
      </div>

      <div class="admin-products">
        <% const vipProducts = products.filter((product) => product.isVip); %>
        <% const regularProducts = products.filter((product) => !product.isVip); %>

        <% if (products.length === 0) { %>
          <div class="empty-state" style="padding: 2rem;">
            <p>Продуктов пока нет.</p>
          </div>
        <% } %>

        <% [
          { title: "VIP-программы", items: vipProducts },
          { title: "Обычные программы", items: regularProducts }
        ].forEach((group) => { %>
          <% if (group.items.length) { %>
            <section class="admin-product-group">
              <div class="admin-product-group__header">
                <h3><%= group.title %></h3>
                <span><%= group.items.length %> шт.</span>
              </div>

              <% group.items.forEach((product) => { %>
                <div class="admin-product-item <%= product.isVip ? 'admin-product-item--vip' : '' %>">
                  <img src="<%= product.imagePath %>" alt="<%= product.title %>" />

                  <div class="admin-product-item__copy">
                    <strong><%= product.title %></strong>
                    <span><%= serviceMap[product.service].name %></span>
                    <% if (product.isVip) { %>
                      <span class="vip-badge vip-badge--admin">VIP</span>
                    <% } %>
                    <% if (product.isNew) { %>
                      <span class="new-badge new-badge--admin">Новая</span>
                    <% } %>
                    <span class="admin-product-item__type"><%= product.productType %></span>
                    <p><%= product.description %></p>
                    <div class="admin-product-item__meta">
                      <span><%= product.imagePaths.length %> фото</span>
                      <span><%= product.originalFileName %></span>
                    </div>
                  </div>

                  <div class="admin-product-item__actions">
                    <a href="/admin/products/<%= product.id %>/edit" class="button button--ghost">Ред.</a>
                    <form method="post" action="/admin/products/<%= product.id %>/delete" onsubmit="return confirm('Удалить этот продукт?')">
                      <button class="button button--danger" type="submit">Удалить</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </section>
          <% } %>
        <% }) %>
      </div>
    </div>
  </div>
</main>

<%- include("partials/footer") %>
